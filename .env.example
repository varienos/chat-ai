HOST=0.0.0.0
PORT=3000
GATEWAY_PORT=3000
GATEWAY_DEV_PORT=3001
REDIS_PORT=6379
POSTGRES_PORT=5432

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/varienai
REDIS_URL=redis://redis:6379
DEFAULT_PROVIDER=codex
ENABLED_PROVIDERS=codex

API_AUTH_TOKEN=change-this-gateway-token
LOG_LEVEL=info
OPENAPI_EXPORT_PATH=docs/openapi/varienai-gateway.openapi.json
POSTMAN_EXPORT_PATH=docs/postman/varienai-gateway.postman_collection.json
POSTMAN_BASE_URL=http://localhost:3000
POSTMAN_COLLECTION_NAME=VarienAI Gateway API
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_MS=60000
REQUEST_BODY_LIMIT_BYTES=1048576

CODEX_BINARY_PATH=codex
CODEX_WORKING_DIRECTORY=/app
CODEX_AUTH_MODE=oauth
OPENAI_API_KEY=
CODEX_MODEL=gpt-5.4
CODEX_ENABLE_DANGEROUS_BYPASS=false
CODEX_SANDBOX=read-only
CODEX_SKIP_GIT_REPO_CHECK=true
CODEX_TIMEOUT_MS=60000
# Paste the contents of ~/.codex/auth.json for headless / Coolify deployments.
# Leave empty for local Docker (use the host fallback instead on macOS).
CODEX_AUTH_JSON=

GEMINI_BINARY_PATH=gemini
GEMINI_WORKING_DIRECTORY=/app
GEMINI_APPROVAL_MODE=plan
GEMINI_SANDBOX=false
GEMINI_TIMEOUT_MS=60000

CLAUDE_BINARY_PATH=claude
CLAUDE_WORKING_DIRECTORY=/app
CLAUDE_PERMISSION_MODE=plan
CLAUDE_INCLUDE_PARTIAL_MESSAGES=true
CLAUDE_TIMEOUT_MS=60000

RECENT_MESSAGE_LIMIT=12
# Override the default assistant persona. Leave empty to use knowledge/system-prompt.md.
# Anything set here is appended to the system prompt for every chat request.
SYSTEM_PROMPT=You are a customer support assistant. Stay on topic and never generate code or content unrelated to the business you serve.

# Deck Admin Panel
# REQUIRED — fill these before `docker compose up`. The compose file uses
# ${VAR:?required} syntax and will fail to start if these are missing.
# Generate strong values with: openssl rand -hex 32
DECK_ADMIN_USER=admin
DECK_ADMIN_PASSWORD=change-me-before-deploy
DECK_JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars-long
