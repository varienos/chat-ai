{
  "openapi": "3.0.3",
  "info": {
    "description": "Codex-first CLI-to-API gateway for customer-facing mobile app development conversations.\n\nProtected routes require `Authorization: Bearer <API_AUTH_TOKEN>`.\nIn Swagger UI, click `Authorize` and paste only the raw `API_AUTH_TOKEN` value. Do not type the `Bearer ` prefix manually.\n\nCodex can be authenticated either through shared OAuth bootstrap or an explicit OpenAI API key when `CODEX_AUTH_MODE=api_key` is configured.",
    "title": "VarienAI Gateway API",
    "version": "0.1.0"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "description": "Gateway bearer token for protected routes. Paste only the raw API_AUTH_TOKEN value into Swagger UI; the UI will add the `Bearer` prefix automatically.",
        "bearerFormat": "opaque",
        "scheme": "bearer",
        "type": "http"
      }
    },
    "schemas": {}
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Get liveness and dependency health",
        "tags": [
          "Runtime"
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "dependencies": {
                      "additionalProperties": {
                        "additionalProperties": false,
                        "properties": {
                          "reason": {
                            "nullable": true,
                            "type": "string"
                          },
                          "status": {
                            "enum": [
                              "up",
                              "down"
                            ],
                            "type": "string"
                          }
                        },
                        "required": [
                          "status"
                        ],
                        "type": "object"
                      },
                      "type": "object"
                    },
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  },
                  "required": [
                    "status"
                  ],
                  "type": "object"
                }
              }
            }
          },
          "503": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "dependencies": {
                      "additionalProperties": {
                        "additionalProperties": false,
                        "properties": {
                          "reason": {
                            "nullable": true,
                            "type": "string"
                          },
                          "status": {
                            "enum": [
                              "up",
                              "down"
                            ],
                            "type": "string"
                          }
                        },
                        "required": [
                          "status"
                        ],
                        "type": "object"
                      },
                      "type": "object"
                    },
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  },
                  "required": [
                    "status"
                  ],
                  "type": "object"
                }
              }
            }
          }
        }
