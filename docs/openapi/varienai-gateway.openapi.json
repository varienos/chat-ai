    "/api/chat/stream": {
      "post": {
        "summary": "Send a chat message and stream the response over SSE",
        "tags": [
          "Chat"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {
                  "message": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "provider": {
                    "type": "string",
                    "example": "codex"
                  },
                  "sessionId": {
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "required": [
                  "message",
                  "sessionId"
                ],
                "type": "object"
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Server-Sent Events stream. Events may include session.started, assistant.delta, assistant.completed, and error.",
            "content": {
              "text/event-stream": {
                "schema": {
                  "example": "event: session.started\ndata: {\"sessionId\":\"ses_123\"}\n\nevent: assistant.delta\ndata: {\"sessionId\":\"ses_123\",\"chunk\":\"Merhaba\"}\n\nevent: assistant.completed\ndata: {\"sessionId\":\"ses_123\",\"provider\":\"codex\",\"message\":{\"id\":\"msg_123\",\"role\":\"assistant\",\"content\":\"Merhaba\"}}\n\n",
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
